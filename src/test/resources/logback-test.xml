<configuration>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Container stdout/stderr forwarded via Slf4jLogConsumer — keep at INFO -->
  <logger name="tc" level="ERROR"/>

  <!-- Testcontainers internals — suppress wire noise -->
  <logger name="org.testcontainers" level="ERROR"/>
  <logger name="com.github.dockerjava" level="ERROR"/>
  <logger name="org.apache.hc" level="ERROR"/>

  <!-- Test classes -->
  <logger name="io.gravitee.reporter.sentry" level="INFO"/>

  <root level="WARN">
    <appender-ref ref="CONSOLE"/>
  </root>

</configuration>
